# Claude (Anthropic) — 브리핑 요약, 코파일럿, 주간 리뷰 AI 생성
ASSISTANT_INTEGRATIONS_CLAUDE_ENABLED=true
ANTHROPIC_API_KEY=sk-ant-...
ASSISTANT_ANTHROPIC_MODEL=claude-sonnet-4-5

# Gemini — 코파일럿 질문 응답 (Claude 이전 우선)
ASSISTANT_INTEGRATIONS_GEMINI_ENABLED=false
GEMINI_API_KEY=
ASSISTANT_GEMINI_MODEL=gemini-2.0-flash

# OpenAI — 아이디어 요약, 코파일럿 fallback
ASSISTANT_INTEGRATIONS_OPENAI_ENABLED=false
OPENAI_API_KEY=
ASSISTANT_OPENAI_MODEL=gpt-4.1

# Google Calendar
ASSISTANT_INTEGRATIONS_CALENDAR_ENABLED=false
ASSISTANT_GOOGLE_CLIENT_ID=
ASSISTANT_GOOGLE_CLIENT_SECRET=
ASSISTANT_GOOGLE_REFRESH_TOKEN=
ASSISTANT_CALENDAR_ID=primary

# Notion
ASSISTANT_NOTION_ENABLED=false
ASSISTANT_NOTION_TOKEN=ntn_...
ASSISTANT_NOTION_BRIEFING_DB_ID=
ASSISTANT_NOTION_IDEA_DB_ID=

# Slack 브리핑 알림
ASSISTANT_SLACK_ENABLED=false
ASSISTANT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
